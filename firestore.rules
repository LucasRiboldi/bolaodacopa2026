rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuários podem ler quase tudo, mas escrever só suas próprias apostas
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth.uid == uid;
    }
    // Admins (documento na coleção admins) podem escrever matches/rankings
    match /admins/{uid} {
      allow read: if true;
      allow write: if false; // ninguém escreve diretamente
    }
    match /matches/{matchId} {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /predictions/{docId} {
      allow read: if true;
      allow create, update: if request.auth.uid != null &&
        request.resource.data.userId == request.auth.uid &&
        get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.startTime > request.time;
      allow delete: if false;
    }
    match /rankings/{uid} {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}